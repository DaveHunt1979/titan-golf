# Supabase — copy this file to .env.local and fill in your project values
# Found in: Supabase Dashboard → Project Settings → API

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Golfbert — course data API (golfbert.com)
# Use the API Key value from your Golfbert dashboard
EXPO_PUBLIC_GOLFBERT_KEY=your-golfbert-api-key-here
