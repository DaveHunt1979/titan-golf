{
  "expo": {
    "name": "titan-golf",
    "slug": "titan-golf",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/TitanAppLogo.png",
    "scheme": "titangolf",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.titangolf.app",
      "buildNumber": "12",
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": ["NDEF", "TAG"]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Titan Golf uses your location to show distances to the green.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Titan Golf uses your location to show distances to the green.",
        "NFCReaderUsageDescription": "Tap your NFC club sticker to identify which club you're hitting."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyBPyekqwVRQ2H3ssieFjWBxq3yhXO8hL8c"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Titan Golf needs camera access to film your shots.",
          "microphonePermission": "Titan Golf needs microphone access to record video.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Titan Golf needs photo library access to save your shots.",
          "savePhotosPermission": "Titan Golf needs permission to save photos and videos.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "newArchEnabled": false,
    "extra": {
      "router": {},
      "eas": {
        "projectId": "595df628-ba81-4fe5-82f7-d33ef97f274d"
      }
    },
    "owner": "davehunt79"
  }
}
